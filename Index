  <script>
    // ── Stars ──
    const starsEl = document.getElementById('stars');
    for (let i = 0; i < 120; i++) {
      const s = document.createElement('div');
      s.className = 'star';
      const size = Math.random() * 2 + 0.5;
      s.style.cssText = `
        width:${size}px; height:${size}px;
        top:${Math.random()*100}%; left:${Math.random()*100}%;
        --d:${2 + Math.random()*4}s;
        --o:${0.1 + Math.random()*0.6};
        animation-delay:${Math.random()*4}s;
      `;
      starsEl.appendChild(s);
    }

    // ── Intersection observer for fade-ups ──
    const obs = new IntersectionObserver(entries => {
      entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
    }, { threshold: 0.1 });
    document.querySelectorAll('.fade-up').forEach(el => obs.observe(el));

    // ── Waitlist ──
    async function submitEmail(email, successId, formId) {
      if (!email || !email.includes('@')) {
        alert('Please enter a valid email address.');
        return;
      }
      // Send to Formspree — replace mzdjgkrl with your Formspree form ID
      try {
        const res = await fetch('https://formspree.io/f/mzdjgkrl', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ email, source: 'jamesfinance-waitlist' }),
        });
        if (res.ok) {
          document.getElementById(formId).style.display = 'none';
          document.getElementById(successId).style.display = 'block';
        } else {
          alert('Something went wrong. Please try again.');
        }
      } catch {
        // Fallback — just show success (you can add a backend later)
        document.getElementById(formId).style.display = 'none';
        document.getElementById(successId).style.display = 'block';
      }
    }

    function joinWaitlist() {
      const email = document.getElementById('email-input').value.trim();
      submitEmail(email, 'success-msg', 'form-wrap');
    }

    function joinWaitlist2() {
      const email = document.getElementById('email-input-2').value.trim();
      submitEmail(email, 'success-msg-2', 'form-wrap-2');
    }

    // Enter key support
    document.getElementById('email-input').addEventListener('keydown', e => { if (e.key === 'Enter') joinWaitlist(); });
    document.getElementById('email-input-2').addEventListener('keydown', e => { if (e.key === 'Enter') joinWaitlist2(); });
  </script>
